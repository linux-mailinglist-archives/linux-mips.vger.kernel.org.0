-		skb->protocol = eth_type_trans(skb, dev);
-		dev->stats.rx_packets++;
-		dev->stats.rx_bytes += skb->len;
-		memset(ATM_SKB(skb), 0, sizeof(struct atm_skb_data));
-		netif_rx(skb);
-	}
