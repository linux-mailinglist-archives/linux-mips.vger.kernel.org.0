-			   ioaddr, ioaddr + ARCNET_TOTAL_SIZE - 1);
-		return -ENXIO;
-	}
-	if (arcnet_inb(ioaddr, COM20020_REG_R_STATUS) == 0xFF) {
-		arc_printk(D_NORMAL, dev, "IO address %x empty\n", ioaddr);
-		err = -ENODEV;
