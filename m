-	arcnet_outb(CFLAGScmd | RESETclear | CONFIGclear,
-		    ioaddr, COM9026_REG_W_COMMAND);
-
-	arc_printk(D_INIT_REASONS, dev, "Status after reset acknowledged: %X\n",
