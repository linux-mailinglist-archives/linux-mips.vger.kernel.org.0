-
-	switch (cmd) {
-	case SIOCMKCLIP:
-	case ATMARPD_CTRL:
-	case ATMARP_MKIP:
-	case ATMARP_SETENTRY:
-	case ATMARP_ENCAP:
-		if (!capable(CAP_NET_ADMIN))
-			return -EPERM;
-		break;
-	default:
-		return -ENOIOCTLCMD;
-	}
-
-	switch (cmd) {
-	case SIOCMKCLIP:
-		err = clip_create(arg);
-		break;
-	case ATMARPD_CTRL:
-		lock_sock(sk);
-		err = atm_init_atmarp(vcc);
-		if (!err) {
-			sock->state = SS_CONNECTED;
-			__module_get(THIS_MODULE);
-		}
-		release_sock(sk);
-		break;
-	case ATMARP_MKIP:
-		lock_sock(sk);
-		err = clip_mkip(vcc, arg);
-		release_sock(sk);
-		break;
-	case ATMARP_SETENTRY:
-		err = clip_setentry(vcc, (__force __be32)arg);
-		break;
-	case ATMARP_ENCAP:
-		err = clip_encap(vcc, arg);
-		break;
