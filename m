-static char *next_string(struct sk_buff *skb)
-{
-	int i = 0;
-	char *this = skb->data;
-	
-	for (i = 0; i < skb->len; i++) {
-		if (this[i] == '\n') {
-			this[i] = 0;
-			skb_pull(skb, i + 1);
-			return this;
-		}
-		if (!isprint(this[i]))
-			return NULL;
-	}
-	return NULL;
-}
