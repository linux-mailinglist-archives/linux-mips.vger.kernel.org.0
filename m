-	short ioaddr = dev->base_addr;
-
-	arcnet_outb(mask, ioaddr, COM9026_REG_W_INTMASK);
-}
-
-static void com90io_copy_to_card(struct net_device *dev, int bufnum,
-				 int offset, void *buf, int count)
-{
