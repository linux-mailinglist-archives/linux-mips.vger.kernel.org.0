-static int
-send_to_lecd(struct lec_priv *priv, atmlec_msg_type type,
-	     const unsigned char *mac_addr, const unsigned char *atm_addr,
-	     struct sk_buff *data)
-{
-	struct atm_vcc *vcc;
-	struct sock *sk;
-	struct sk_buff *skb;
-	struct atmlec_msg *mesg;
-
-	if (!priv || !rcu_access_pointer(priv->lecd))
