-						 */
-	unsigned long path_switching_delay;
-
-	u8 *tlvs;				/* LANE2: TLVs are new */
-	u32 sizeoftlvs;				/* The size of the tlv array in bytes */
-	int lane_version;			/* LANE2 */
-	int itfnum;				/* e.g. 2 for lec2, 5 for lec5 */
