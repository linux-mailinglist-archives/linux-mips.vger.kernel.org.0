-
-	pr_debug("\n");
-	if (entry->status == ESI_ARP_PENDING) {
-		if (entry->no_tries <= entry->priv->max_retry_count) {
-			if (entry->is_rdesc)
-				send_to_lecd(entry->priv, l_rdesc_arp_xmt,
-					     entry->mac_addr, NULL, NULL);
-			else
-				send_to_lecd(entry->priv, l_arp_xmt,
-					     entry->mac_addr, NULL, NULL);
