-#define SOLOS_GPIO_ATTR(_name, _mode, _show, _store, _offset)	\
-	struct geos_gpio_attr gpio_attr_##_name = {		\
-		.attr = __ATTR(_name, _mode, _show, _store),	\
-		.offset = _offset }
