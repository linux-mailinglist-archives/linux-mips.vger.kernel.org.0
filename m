-static int print_buffer(struct sk_buff *buf)
-{
-	int len,i;
-	char msg[500];
-	char item[10];
-
-	len = buf->len;
-	for (i = 0; i < len; i++){
-		if(i % 8 == 0)
-			sprintf(msg, "%02X: ", i);
-
-		sprintf(item,"%02X ",*(buf->data + i));
-		strcat(msg, item);
-		if(i % 8 == 7) {
-			sprintf(item, "\n");
-			strcat(msg, item);
-			printk(KERN_DEBUG "%s", msg);
-		}
-	}
-	if (i % 8 != 0) {
-		sprintf(item, "\n");
-		strcat(msg, item);
-		printk(KERN_DEBUG "%s", msg);
-	}
-	printk(KERN_DEBUG "\n");
-
-	return 0;
-}
