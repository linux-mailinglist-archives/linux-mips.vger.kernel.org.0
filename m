-	unsigned long airqmask;
-
-	if (BUGLVL(D_NORMAL)) {
-		pr_info("%s\n", "COM90xx IO-mapped mode support (by David Woodhouse et el.)");
-		pr_info("E-mail me if you actually test this driver, please!\n");
