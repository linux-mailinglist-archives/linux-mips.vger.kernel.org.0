-
-	unregister_netdev(dev);
-
-	/* In case the old driver is loaded later,
-	 * set the thing back to MMAP mode
-	 */
-	arcnet_outb(arcnet_inb(ioaddr, COM9026_REG_RW_CONFIG) & ~IOMAPflag,
-		    ioaddr, COM9026_REG_RW_CONFIG);
